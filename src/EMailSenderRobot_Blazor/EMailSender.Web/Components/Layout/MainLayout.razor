@using EMailSender.Core.Services
@using EMailSender.Core.Models
@using System.Reflection
@inherits LayoutComponentBase

<div class="d-flex flex-column" style="min-height:100vh">
    <nav class="navbar navbar-dark bg-dark px-3 d-flex justify-content-between">
        <a class="navbar-brand fw-bold" href="/">📧 EMailSender</a>
        <span class="text-secondary small align-self-center">v@_version</span>
    </nav>

    <div class="container-fluid flex-grow-1">
        <div class="row h-100">
            <!-- Sidebar -->
            <nav class="col-md-2 bg-dark py-3 ps-3 pe-2" style="min-height:calc(100vh - 56px)">
                <ul class="nav flex-column gap-1">
                    <li class="nav-item">
                        <NavLink class="nav-link text-secondary" href="/" Match="NavLinkMatch.All">
                            Monitor mail
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-secondary" href="/log">
                            Scheduler Logs
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-secondary" href="/companies">
                            Impostazioni Tenant
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-secondary" href="/smtpconfig">
                            Config SMTP
                        </NavLink>
                    </li>
                </ul>
            </nav>

            <!-- Contenuto -->
            <main class="col-md-10 py-4 px-4">
                @Body
            </main>
        </div>
    </div>
</div>

@code {
    [Inject] ConfigService Cfg { get; set; } = default!;

    private string _version = "";

    protected override void OnInitialized()
    {
        _version = Assembly.GetExecutingAssembly()
                           .GetName()
                           .Version?
                           .ToString() ?? "—";
    }
}