@using EMailSender.Core.Services
@using EMailSender.Core.Models
@using System.Reflection
@inherits LayoutComponentBase
@inject TenantService TenantSvc
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="d-flex flex-column" style="min-height:100vh">
    <nav class="navbar navbar-dark bg-dark px-3">
        <a class="navbar-brand fw-bold me-4" href="/">EMailSender</a>
        <ul class="nav me-3">
            <li class="nav-item">
                <NavLink class="nav-link text-secondary px-3" href="/" Match="NavLinkMatch.All">
                    Monitor mail
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link text-secondary px-3" href="/log">
                    Scheduler Logs
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link text-secondary px-3" href="/emaileditor">
                    Email Editor
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link text-secondary px-3" href="/companies">
                    Impostazioni Tenant
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link text-secondary px-3" href="/smtpconfig">
                    Config SMTP
                </NavLink>
            </li>
        </ul>
        <span class="text-secondary small">v@_version</span>
    </nav>
    <main class="container-fluid py-4 px-4">
        @Body
    </main>
</div>

@code {
    private string _version = "";

    protected override void OnInitialized()
    {
        _version = Assembly.GetExecutingAssembly()
                           .GetName()
                           .Version?
                           .ToString() ?? "—";
    }
}