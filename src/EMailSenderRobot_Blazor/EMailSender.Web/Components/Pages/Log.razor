@page "/log"
@rendermode InteractiveServer
@using EMailSender.Core.Data
@using EMailSender.Core.Models
@using EMailSender.Core.Services
@inject ConfigService Cfg
@inject TenantService TenantSvc
@inject IJSRuntime JS

<h4 class="mb-3">Log applicativo</h4>

<div class="row g-2 mb-3 align-items-center">
    <div class="col-auto">
        <select class="form-select form-select-sm" @bind="_selectedCompany" @bind:after="OnCompanyChanged">
            <option value="">— Tutti i tenant —</option>
            @foreach (var c in _companies)
            {
                <option value="@c.Name">@c.DisplayName</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <select class="form-select form-select-sm" @bind="_filterTipo">
            <option value="">— Tutti i tipi —</option>
            <option value="RISULTATO">RISULTATO</option>
            <option value="ERRORE">ERRORE</option>
            <option value="GENERALE">GENERALE</option>
        </select>
    </div>
    <div class="col-auto">
        <button class="btn btn-sm btn-primary" @onclick="LoadLogs">Filtra</button>
        <button class="btn btn-sm btn-outline-secondary" @onclick="Reset">Reset</button>
    </div>
</div>

@if (_loading)
{
    <div class="d-flex align-items-center gap-2 mt-3">
        <div class="spinner-border spinner-border-sm text-secondary"></div>
        <span class="text-muted">Caricamento...</span>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle" style="font-size:.85rem">
            <thead class="table-dark">
                <tr>
                    <th>Data</th>
                    <th>Ora</th>
                    <th>Tenant</th>
                    <th>Tipo</th>
                    <th>Operazione</th>
                    <th>Descrizione</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in _entries)
                {
                    var rowCss = e.Tipo == "ERRORE" ? "table-danger" :
                    e.Tipo == "RISULTATO" ? "table-success" : "";
                    <tr class="@rowCss">
                        <td>@e.Data</td>
                        <td>@e.Ora</td>
                        <td>@e.Company</td>
                        <td>
                            <span class="badge @(e.Tipo == "ERRORE" ? "bg-danger" : e.Tipo == "RISULTATO" ? "bg-success" : "bg-secondary")">
                                @e.Tipo
                            </span>
                        </td>
                        <td>@e.Operazione</td>
                        <td>@e.Descr</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!_entries.Any())
    {
        <p class="text-muted">Nessun log trovato.</p>
    }
}

@code {
    private List<CompanySettings> _companies = [];
    private string _selectedCompany = "";
    private List<LogEntry> _entries = [];
    private string _filterTipo = "";
    private bool _loading = false;

    protected override void OnInitialized()
    {
        _companies = Cfg.GetAllCompanies();
        _selectedCompany = TenantSvc.SelectedCompany;
        _ = LoadLogs();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && string.IsNullOrWhiteSpace(_selectedCompany))
        {
            var saved = await JS.InvokeAsync<string?>("sessionStorage.getItem", "selectedCompany");
            if (!string.IsNullOrWhiteSpace(saved))
            {
                _selectedCompany = saved;
                TenantSvc.SelectedCompany = saved;
                _ = LoadLogs();
                StateHasChanged();
            }
        }
    }

    private async Task OnCompanyChanged()
    {
        TenantSvc.SelectedCompany = _selectedCompany;
        await JS.InvokeVoidAsync("sessionStorage.setItem", "selectedCompany", _selectedCompany);
        _ = LoadLogs();
    }

    private async Task LoadLogs()
    {
        _loading = true;
        StateHasChanged();
        await Task.Yield();

        _entries = [];

        var targets = string.IsNullOrWhiteSpace(_selectedCompany)
            ? _companies
            : _companies.Where(c => c.Name == _selectedCompany).ToList();

        foreach (var c in targets)
        {
            var connStr = Cfg.GetConnectionString($"{c.Name}_Log");
            if (string.IsNullOrWhiteSpace(connStr)) continue;

            var repo = new EmailRepository(connStr);
            var entries = repo.GetRecentLogs(top: 300);

            if (!string.IsNullOrWhiteSpace(_filterTipo))
                entries = entries.Where(e => e.Tipo == _filterTipo).ToList();

            _entries.AddRange(entries);
        }

        _entries = [.. _entries.OrderByDescending(e => e.Id)];

        _loading = false;
        StateHasChanged();
    }

    private void Reset()
    {
        _filterTipo = "";
        _ = LoadLogs();
    }
}