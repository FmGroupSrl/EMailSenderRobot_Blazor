@page "/smtpconfig"
@rendermode InteractiveServer
@using EMailSender.Core.Data
@using EMailSender.Core.Models
@using EMailSender.Core.Services
@inject ConfigService Cfg

<h4 class="mb-3">Configurazione SMTP</h4>

@* Selezione tenant *@
<div class="row g-2 mb-4">
    <div class="col-auto">
        <select class="form-select" @bind="_selectedCompany" @bind:after="LoadConfig">
            <option value="">— Seleziona tenant —</option>
            @foreach (var c in _companies)
            {
                <option value="@c.Name">@c.DisplayName</option>
            }
        </select>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_selectedCompany))
{

    <p class="@(_cfg.IsDeliveryBlocked ? "text-danger" : "text-success") small">
        Stato spedizioni:
        @(_cfg.IsDeliveryBlocked
            ? "Servizio fermato — modificabile da Tenant Setup"
            : "Servizio attivo")
</p>

    @* --- CARD SMTP --- *@
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-dark text-white">
            Parametri SMTP — @SelectedDisplayName
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Server SMTP</label>
                    <input class="form-control" @bind="_cfg.Smtp_Server"
                           placeholder="smtp.example.com" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Porta</label>
                    <input type="number" class="form-control" @bind="_cfg.Smtp_Port" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox"
                               @bind="_cfg.Smtp_Ssl" id="chkSsl" />
                        <label class="form-check-label" for="chkSsl">SSL</label>
                    </div>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox"
                               @bind="_cfg.Smtp_StartTls" id="chkTls" />
                        <label class="form-check-label" for="chkTls">StartTLS</label>
                    </div>
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox"
                               @bind="_cfg.Smtp_Auth" id="chkAuth" />
                        <label class="form-check-label" for="chkAuth">Autenticazione</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Utente SMTP</label>
                    <input class="form-control" @bind="_cfg.Smtp_User"
                           disabled="@(!_cfg.Smtp_Auth)" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Password SMTP</label>
                    <input type="password" class="form-control" @bind="_cfg.Smtp_Password"
                           disabled="@(!_cfg.Smtp_Auth)" />
                </div>

                <div class="col-md-5">
                    <label class="form-label fw-semibold">Indirizzo mittente</label>
                    <input class="form-control" @bind="_cfg.Smtp_Sender"
                           placeholder="noreply@example.com" />
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-semibold">Alias mittente</label>
                    <input class="form-control" @bind="_cfg.Smtp_SenderAlias"
                           placeholder="Nome Azienda" />
                </div>

                @if (!string.IsNullOrEmpty(_saveMessage))
                {
                    <div class="col-12">
                        <div class="alert @(_isSaveError ? "alert-danger" : "alert-success") py-1">
                            @_saveMessage
                        </div>
                    </div>
                }

                <div class="col-12 text-end">
                    <button class="btn btn-outline-secondary me-2" @onclick="LoadConfig">
                        ↺ Ricarica
                    </button>
                    <button class="btn btn-primary" @onclick="SaveConfig">
                        💾 Salva
                    </button>
                </div>
            </div>
        </div>
    </div>

    @* --- CARD TEST MAIL --- *@
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-dark text-white">
            Test invio mail — @SelectedDisplayName
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label fw-semibold">Destinatario test</label>
                    <input class="form-control" @bind="_testEmailTo"
                           placeholder="destinatario@example.com" />
                </div>
                <div class="col-auto">
                    <button class="btn btn-outline-primary" @onclick="SendTestEmail"
                            disabled="@_testRunning">
                        @if (_testRunning)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        📨 Invia mail di test
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_testResultMessage))
            {
                <div class="mt-3 alert @(_testIsError ? "alert-danger" : "alert-success")">
                    <div class="fw-bold mb-1">@(_testIsError ? "❌ KO" : "✅ OK")</div>
                    <div>@_testResultMessage</div>
                    @if (!string.IsNullOrEmpty(_testServerDetails))
                    {
                        <hr class="my-2" />
                        <small class="text-muted font-monospace">@_testServerDetails</small>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private List<CompanySettings> _companies = [];
    private string _selectedCompany = "";

    // SMTP
    private EmailServerConfig _cfg = new();
    private string _saveMessage = "";
    private bool _isSaveError;

    // Test mail
    private string _testEmailTo = "";
    private bool _testRunning;
    private bool _testIsError;
    private string _testResultMessage = "";
    private string _testServerDetails = "";

    private string SelectedDisplayName =>
        _companies.FirstOrDefault(c => c.Name == _selectedCompany)?.DisplayName ?? _selectedCompany;

    protected override void OnInitialized()
        => _companies = Cfg.GetAllCompanies();

    private void LoadConfig()
    {
        _saveMessage = "";
        _isSaveError = false;
        _testResultMessage = "";
        _testServerDetails = "";

        if (string.IsNullOrWhiteSpace(_selectedCompany)) return;

        var companyCfg = _companies.FirstOrDefault(c => c.Name == _selectedCompany);
        if (companyCfg is null) return;

        var connStr = Cfg.GetConnectionString($"{_selectedCompany}_Main");
        if (string.IsNullOrWhiteSpace(connStr))
        {
            _saveMessage = $"Connection string '{_selectedCompany}_Main' non trovata.";
            _isSaveError = true;
            return;
        }

        var repo = new EmailRepository(connStr);
        var result = repo.GetServerConfig(_selectedCompany, companyCfg.SqlConfigTableServer);
        _cfg = result ?? new EmailServerConfig { Company = _selectedCompany };

        if (result is null)
            _saveMessage = "Nessuna configurazione SMTP trovata — verrà creata al salvataggio.";
    }

    private void SaveConfig()
    {
        _saveMessage = "";
        _isSaveError = false;

        var companyCfg = _companies.FirstOrDefault(c => c.Name == _selectedCompany);
        if (companyCfg is null) return;

        var connStr = Cfg.GetConnectionString($"{_selectedCompany}_Main");
        if (string.IsNullOrWhiteSpace(connStr))
        {
            _saveMessage = $"Connection string '{_selectedCompany}_Main' non trovata.";
            _isSaveError = true;
            return;
        }

        try
        {
            var repo = new EmailRepository(connStr);
            repo.SaveServerConfig(_cfg, companyCfg.SqlConfigTableServer);
            _saveMessage = "Configurazione SMTP salvata.";
        }
        catch (Exception ex)
        {
            _saveMessage = $"Errore: {ex.Message}";
            _isSaveError = true;
        }
    }

    private async Task SendTestEmail()
    {
        _testResultMessage = "";
        _testServerDetails = "";
        _testIsError = false;
        _testRunning = true;
        StateHasChanged();

        await Task.Run(() =>
        {
            var svc = new MailSenderService();
            svc.SetServerConfig(_cfg);

            svc.TO = [_testEmailTo];
            svc.EmailObject = $"[TEST] EMailSender — {SelectedDisplayName} — {DateTime.Now:dd/MM/yyyy HH:mm}";
            svc.EmailFullBody = $"Mail di test inviata da EMailSender Robot.<br/><br/>" +
                                $"Tenant: <b>{SelectedDisplayName}</b><br/>" +
                                $"Server: {_cfg.Smtp_Server}:{_cfg.Smtp_Port}<br/>" +
                                $"Mittente: {_cfg.Smtp_Sender}<br/>" +
                                $"Data/ora: {DateTime.Now:dd/MM/yyyy HH:mm:ss}";

            bool hasError = svc.SendEmail(isHtml: true, attempts: 1);

            _testIsError = hasError;
            _testResultMessage = hasError
                ? svc.ErrorMessage
                : $"Mail inviata correttamente a {_testEmailTo}";

            _testServerDetails = svc.GetServerDetails();
        });

        _testRunning = false;
    }
}